# примеры API-запросов

# получение объявлений
GET http://localhost:8000/api/advertisements/
Content-Type: application/json

###
# создание объявления
POST http://localhost:8000/api/advertisements/
Content-Type: application/json
Authorization: Token 6dd3385c5bad6e507a982e61ac53ac09b795ebc0

{
  "title": "Шкаф IKEA",
  "description": "Срочно"
}

###

# попытка поменять объявление
PATCH http://localhost:8000/api/advertisements/1/
Content-Type: application/json
Authorization: Token 6dd3385c5bad6e507a982e61ac53ac09b795ebc0

{
  "status": "CLOSED"
}

###

# фильтрация по дате
GET http://localhost:8000/api/advertisements/?created_at_before=2026-04-06
Content-Type: application/json

###

# фильтрация по статусу
GET http://localhost:8000/api/advertisements/?status=CLOSED
Content-Type: application/json

###

# фильтрация по создателю
GET http://localhost:8000/api/advertisements/?creator=2
Content-Type: application/json
